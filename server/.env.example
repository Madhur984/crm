# ── Recon Core API — environment variables ───────────────────────────────
# Local dev: copy to server/.env  ·  Production: set these in Vercel
# (Project → Settings → Environment Variables). NEVER commit real secrets.

# Neon Postgres connection string.
#  - On Vercel (serverless) use the POOLED connection (host contains "-pooler").
#  - Locally you can use either; the direct one is fine.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret used to sign login tokens. Use a long random value (48+ bytes).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-long-random-string"

# How long a login stays valid. Optional (default 7d).
JWT_EXPIRES_IN="7d"

# Data driver: "postgres" (default → Prisma/SQL) or "firestore". Leave as postgres.
DB_DRIVER="postgres"

# Only needed if the frontend is served from a DIFFERENT origin than the API.
# On Vercel they share one domain, so leave this unset.
# CLIENT_ORIGIN="https://your-app.vercel.app"

# PORT is for local dev only. Vercel sets this automatically — do NOT set it there.
# PORT=4000
