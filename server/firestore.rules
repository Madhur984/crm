rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && getUserData().orgId == orgId;
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow write: if false; // Admin only
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false;
    }

    // Projects & Subcollections
    match /projects/{projectId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.orgId);
      allow write: if isAuthenticated() && isOrgMember(resource.data.orgId);

      match /bom/{bomId} {
        allow read, write: if isAuthenticated();
      }

      match /clarifications/{clarificationId} {
        allow read, write: if isAuthenticated();

        match /messages/{messageId} {
          allow read, write: if isAuthenticated();
        }
      }

      match /invoices/{invoiceId} {
        allow read, write: if isAuthenticated();
      }

      match /activities/{activityId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Documents
    match /documents/{docId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.orgId);
      allow write: if false;
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Messages (Support & Activity replies)
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
